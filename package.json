{
  "name": "jlaine.net",
  "version": "1.0.0",
  "description": "Static site for jlaine.net",
  "scripts": {
    "test": "npm run test:unit && npm run test:map",
    "test:unit": "c8 --100 --reporter=text --include='source/beach-volleyball/map-data.js' node --test 'tests/unit/**/*.test.js'",
    "test:map": "bundle exec jekyll build && playwright test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jarkko/jlaine.net.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jarkko/jlaine.net/issues"
  },
  "homepage": "https://github.com/jarkko/jlaine.net#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "c8": "^11.0.0"
  }
}
