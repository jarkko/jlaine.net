{
  "name": "jlaine.net",
  "version": "1.0.0",
  "description": "Static site for jlaine.net",
  "scripts": {
    "build": "bundle exec jekyll build",
    "check": "npm run lint && npm run format:check && npm run test:unit && npm run test:e2e && npm run test:a11y",
    "format": "prettier --write \"source/beach-volleyball/**/*.{html,css,js}\" \"tests/**/*.js\" \"playwright.config.js\" \"eslint.config.js\" \"package*.json\" \".github/workflows/*.yml\" \".github/pull_request_template.md\" \".prettierrc.json\"",
    "format:check": "prettier --check \"source/beach-volleyball/**/*.{html,css,js}\" \"tests/**/*.js\" \"playwright.config.js\" \"eslint.config.js\" \"package*.json\" \".github/workflows/*.yml\" \".github/pull_request_template.md\" \".prettierrc.json\"",
    "lint": "eslint \"source/beach-volleyball/**/*.js\" \"tests/**/*.js\" \"playwright.config.js\" \"eslint.config.js\"",
    "test": "npm run check",
    "test:a11y": "npm run build && playwright test tests/a11y.spec.js",
    "test:e2e": "npm run build && playwright test tests/beach-volleyball.spec.js",
    "test:map": "npm run build && playwright test",
    "test:unit": "c8 --100 --reporter=text --include='source/beach-volleyball/map-data.js' node --test 'tests/unit/**/*.test.js'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jarkko/jlaine.net.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jarkko/jlaine.net/issues"
  },
  "homepage": "https://github.com/jarkko/jlaine.net#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "c8": "^11.0.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3"
  }
}
